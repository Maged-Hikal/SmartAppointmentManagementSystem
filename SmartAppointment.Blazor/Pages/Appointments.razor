@page "/appointments"
@using SmartAppointment.Blazor.Models
@using SmartAppointment.Blazor.Services
@inject AppointmentApiService Api
@inject NavigationManager Nav
@attribute [Authorize]

<div class="max-w-6xl mx-auto p-6">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <div>
            <h3 class="text-3xl font-bold text-gray-800">Appointments</h3>
            <p class="text-gray-600">Manage and track your scheduled visits.</p>
        </div>
        <a href="/appointments/create" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg shadow-md transition font-medium flex items-center">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
            New Appointment
        </a>
    </div>

    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-200 mb-6 flex flex-col md:flex-row gap-4">
        <div class="relative flex-grow">
            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </span>
            <input type="text"
                   class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition"
                   placeholder="Search by Name or SSN..."
                   @bind="SearchTerm" @bind:event="oninput" />
        </div>
        <div class="flex gap-2">
            <select @bind="StatusFilter" class="block w-full pl-3 pr-10 py-2 text-base border border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-lg transition bg-white">
                <option value="">All Statuses</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
    </div>

    @if (appointments == null)
    {
        <div class="flex flex-col items-center justify-center p-20 bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
            <p class="text-gray-500 font-medium">Loading your schedule...</p>
        </div>
    }
    else if (!FilteredAppointments.Any())
    {
        <div class="text-center py-20 bg-white rounded-xl border border-gray-200 shadow-sm">
            <div class="text-gray-300 text-6xl mb-4 flex justify-center">
                <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </div>
            <p class="text-gray-500 text-lg font-medium">No appointments match your criteria.</p>
            <button @onclick="ClearFilters" class="text-blue-600 mt-2 font-semibold hover:underline">Clear all filters</button>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Customer</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Date & Time</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Created At</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Contact</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var a in FilteredAppointments)
                        {
                            <tr class="hover:bg-gray-50/80 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-900">@a.CustomerName</div>
                                    <div class="text-xs text-danger font-mono">SSN:@a.SSN</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-700 font-semibold">@a.Date.ToString("MMM dd, yyyy")</div>
                                    <div class="text-xs text-blue-600 font-medium">@a.Date.ToString("hh:mm tt")</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-700 font-semibold">@a.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="text-xs text-blue-600 font-medium">@a.CreatedAt.ToString("hh:mm tt")</div>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <div class="text-gray-600">@a.Email</div>
                                    <div class="text-primary text-xs">Tel:@a.PhoneNumber</div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="@GetStatusClass(a.Status)">
                                        @a.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right space-x-1">
                                    @if (CanApprove(a.Status))
                                    {
                                        <button title="Approve" @onclick="() => Approve(a.Id)" class="p-2 text-green-600 hover:bg-green-50 rounded-full transition">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                        </button>
                                    }
                                    @if (CanReschedule(a.Status))
                                    {
                                        <button title="Reschedule" @onclick="() => PrepareReschedule(a.Id, a.CustomerName, a.Date)" class="p-2 text-blue-600 hover:bg-blue-50 rounded-full transition">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                        </button>
                                    }
                                    @if (CanCancel(a.Status))
                                    {
                                        <button title="Cancel" @onclick="() => CancelAsync(a.Id)" class="p-2 text-orange-500 hover:bg-orange-50 rounded-full transition">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        </button>
                                    }
                                    @if (CanDelete(a.Status))
                                    {
                                        <button title="Delete" @onclick="() => Reject(a.Id)" class="p-2 text-red-600 hover:bg-red-50 rounded-full transition">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm transition-opacity">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden animate-in fade-in zoom-in duration-200">
            <div class="bg-blue-600 p-6 text-white flex justify-between items-center">
                <div>
                    <h5 class="text-xl font-bold">Reschedule</h5>
                    <p class="text-blue-100 text-xs">Modifying appointment for @targetCustomerName</p>
                </div>
                <button @onclick="CloseModal" class="text-white/80 hover:text-white text-2xl leading-none">&times;</button>
            </div>

            <div class="p-6">
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2 italic">1. Select New Date</label>
                    <input type="date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition"
                           value="@rescheduleDate.ToString("yyyy-MM-dd")"
                           @onchange="@((ChangeEventArgs e) => rescheduleDate = DateTime.Parse(e.Value?.ToString() ?? DateTime.Today.ToString()))"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <label class="block text-sm font-semibold text-gray-700 mb-2 italic">2. Select New Time (@rescheduleDate.ToShortDateString())</label>
                <div class="grid grid-cols-4 gap-2 max-h-60 overflow-y-auto p-1 custom-scrollbar">
                    @foreach (var slot in TimeSlots)
                    {
                        <button type="button"
                                @onclick="() => ConfirmReschedule(slot)"
                                class="@(IsSelected(slot) ? "bg-blue-600 text-white border-blue-600 shadow-md scale-105" : "bg-white text-blue-600 border-blue-200 hover:border-blue-400 hover:bg-blue-50") border rounded-md py-2 text-xs font-bold transition-all">
                            @DateTime.Today.Add(slot).ToString("hh:mm tt")
                        </button>
                    }
                </div>
            </div>

            <div class="bg-gray-50 p-4 flex justify-end gap-3">
                <button class="px-6 py-2 text-gray-500 hover:text-gray-700 font-medium text-sm" @onclick="CloseModal">Discard Changes</button>
            </div>
        </div>
    </div>
}

@code {
    private string GetStatusClass(string? status)
    {
        var baseStyle = "px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ";
        return status?.ToLower() switch
        {
            "approved" => baseStyle + "bg-green-100 text-green-700",
            "pending" => baseStyle + "bg-yellow-100 text-yellow-700",
            "cancelled" => baseStyle + "bg-orange-100 text-orange-700",
            "rejected" or "deleted" => baseStyle + "bg-red-100 text-red-700",
            _ => baseStyle + "bg-gray-100 text-gray-700"
        };
    }
    private string SearchTerm { get; set; } = "";
    private string StatusFilter { get; set; } = "";

    // This property does the filtering logic automatically in the UI
    private IEnumerable<AppointmentModel>? FilteredAppointments =>
        appointments?.Where(a =>
            (string.IsNullOrWhiteSpace(SearchTerm) ||
             a.CustomerName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
             a.SSN.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(StatusFilter) || a.Status == StatusFilter)
        );

    private void ClearFilters()
    {
        SearchTerm = "";
        StatusFilter = "";
    }
}