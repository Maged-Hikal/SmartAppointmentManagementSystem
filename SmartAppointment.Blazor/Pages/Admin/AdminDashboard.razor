@page "/d/a"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,SuperAdmin")]
@inject NavigationManager Nav

<h3>Admin Dashboard</h3>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Appointments</h5>
                <p><a class="btn btn-primary" href="/appointments">Manage Appointments</a></p>
            </div>
        </div>
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p><button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/admin/users")'>View Users</button></p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Shortcuts</h5>
                <p><button class="btn btn-outline-primary" @onclick='() => Nav.NavigateTo("/admin/permissions")'>Permissions</button></p>
            </div>
        </div>
    </div>
</div>

