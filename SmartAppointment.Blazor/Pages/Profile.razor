@page "/profile"
@using SmartAppointment.Blazor.Models
@using SmartAppointment.Blazor.Services
@using System.ComponentModel.DataAnnotations
@inject AppointmentApiService Api
@attribute [Authorize]

<div class="max-w-4xl mx-auto p-6 space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h3 class="text-3xl font-bold text-gray-800">Account Settings</h3>
            <p class="text-gray-600">Update your profile and Contact informations.</p>
        </div>
        <div class="hidden md:block">
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold uppercase tracking-widest">User Profile</span>
        </div>
    </div>

    @if (userModel == null)
    {
        <div class="flex flex-col items-center justify-center p-20 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
            <p class="text-gray-500">Retrieving your information...</p>
        </div>
    }
    else
    {
        <EditForm Model="@userModel" OnValidSubmit="UpdateProfile">
            <DataAnnotationsValidator />
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="h-24 bg-gradient-to-r from-blue-500 to-blue-700 p-6 flex items-center justify-between">
                    <h4 class="text-white font-bold text-lg">Personal Details</h4>
                    <div class="h-12 w-12 bg-white/20 backdrop-blur rounded-lg flex items-center justify-center text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    </div>
                </div>

                <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Full Name</label>
                        <p class="text-lg font-semibold text-gray-800 py-1 border-b border-gray-50">@userModel.UserName</p>
                    </div>
                    <div class="md:col-span-2">
                        <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">SSN</label>
                        <p class="text-lg font-semibold text-gray-800 py-1 border-b border-gray-50">@userModel.SSN</p>
                    </div>

                    <div class="space-y-1">
                        <label class="block text-sm font-semibold text-gray-700">Email</label>
                        <InputText @bind-Value="userModel.Email" class="@InputStyle" />
                        <ValidationMessage For="@(() => userModel.Email)" class="text-red-500 text-xs" />
                    </div>

                    <div class="space-y-1">
                        <label class="block text-sm font-semibold text-gray-700">Phone</label>
                        <InputText @bind-Value="userModel.PhoneNumber" class="@InputStyle" />
                        <ValidationMessage For="@(() => userModel.PhoneNumber)" class="text-red-500 text-xs" />
                    </div>

                   

                    <div class="md:col-span-2 flex items-center justify-between pt-4 border-t border-gray-50">
                        @if (profileSaved)
                        {
                            <span class="text-green-600 text-success font-bold flex items-center">
                                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" /></svg>
                                Profile Saved!
                            </span>
                        }
                        else
                        {

                            <span></span>
                        }
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-bold transition shadow-md disabled:opacity-50">
                            Save Profile
                        </button>
                    </div>
                </div>
            </div>
        </EditForm>

        <EditForm Model="@passwordModel" OnValidSubmit="ChangePassword">
            <DataAnnotationsValidator />
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="p-6 border-b border-gray-100 flex items-center space-x-3">
                    <div class="p-2 bg-red-50 text-red-600 rounded-lg">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                    </div>
                    <h4 class="text-lg font-bold text-gray-800">Security</h4>
                </div>

                <div class="p-8 space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700">Current Password</label>
                            <InputText type="password" @bind-Value="passwordModel.CurrentPassword" class="@InputStyle" />
                            <ValidationMessage For="@(() => passwordModel.CurrentPassword)" class="text-red-500 text-xs" />
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700">New Password</label>
                            <div class="relative flex items-center">
                                <InputText type="@(showPassword ? "text" : "password")"
                                           @bind-Value="passwordModel.NewPassword"
                                           class="@InputStyle" autocomplete="new-password" />

                                <button type="button"
                                        @onclick="TogglePasswordVisibility"
                                        class="absolute right-3 focus:outline-none flex items-center justify-center"
                                        style="height: 100%; top: 0;">
                                    @if (showPassword)
                                    {
                                        <span class="bi-eye-slash-fill-nav-menu" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <span class="bi-eye-fill-nav-menu" aria-hidden="true"></span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(passError))
                    {
                        <p class="text-red-600 text-sm font-medium">@passError</p>
                    }
                    @if (passSuccess)
                    {
                        <p class="text-green-600 text-success font-medium">Password updated successfully!</p>
                    }

                    <div class="pt-4 flex justify-end">
                        <button type="submit" class="bg-gray-800 hover:bg-black text-white px-6 py-2 rounded-xl font-bold transition">
                            Update Password
                        </button>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {

    private string InputStyle => "block w-full pl-4 pr-10 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white focus:outline-none transition-all sm:text-sm";
   
}