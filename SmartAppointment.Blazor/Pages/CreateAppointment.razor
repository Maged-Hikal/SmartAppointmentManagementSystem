@page "/appointments/create"
@using Microsoft.AspNetCore.Authorization
@using SmartAppointment.Blazor.Models
@using SmartAppointment.Blazor.Services
@inject AppointmentApiService Api
@attribute [Authorize]

<div class="max-w-4xl mx-auto p-6">
    <div class="mb-8">
        <h3 class="text-3xl font-bold text-gray-800">Create Appointment</h3>
        <p class="text-gray-600">Please fill in the details below to schedule your visit.</p>
    </div>

    <EditForm Model="@model" OnValidSubmit="HandleSubmit" class="space-y-8">
        <DataAnnotationsValidator />

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex items-center mb-4 border-b pb-2">
                <span class="text-blue-600 mr-2"><i class="fas fa-user"></i></span>
                <h4 class="text-lg font-semibold text-gray-700">Customer Information</h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Customer Name</label>
                    <InputText class="@InputClass" @bind-Value="model.CustomerName" readonly="@IsReadOnly" placeholder="Full Name" />
                    <ValidationMessage For="() => model.CustomerName" class="text-red-500 text-xs mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">SSN</label>
                    <InputText class="@InputClass" @bind-Value="model.SSN" readonly="@IsReadOnly" placeholder="000-00-0000" />
                    <ValidationMessage For="() => model.SSN" class="text-red-500 text-xs mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                    <InputText type="email" class="@InputClass" @bind-Value="model.Email" readonly="@IsReadOnly" placeholder="email@example.com" />
                    <ValidationMessage For="() => model.Email" class="text-red-500 text-xs mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                    <InputText type="tel" class="@InputClass" @bind-Value="model.PhoneNumber" readonly="@IsReadOnly" placeholder="+1 (555) 000-0000" />
                    <ValidationMessage For="() => model.PhoneNumber" class="text-red-500 text-xs mt-1" />
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex items-center mb-4 border-b pb-2">
                <span class="text-blue-600 mr-2"><i class="fas fa-calendar-alt"></i></span>
                <h4 class="text-lg font-semibold text-gray-700">Appointment Details</h4>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Pick Date</label>
                <InputDate Type="InputDateType.Date"
                           class="w-full md:w-1/3 block px-4 py-2 border rounded-lg focus:ring-blue-500 focus:border-blue-500 text-gray-900 "
                           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           @bind-Value="model.Date" />
                <ValidationMessage For="() => model.Date" class="text-red-500 text-xs mt-1" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-3">
                    Select Available Time
                    <span class="text-blue-600 font-bold ml-2">@model.Date.ToString("t")</span>
                </label>
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
                    @foreach (var slot in TimeSlots)
                    {
                        <button type="button"
                                @onclick="() => SelectTime(slot)"
                                class="@GetTimeSlotClass(slot)">
                            @slot.ToString(@"hh\:mm")
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="mt-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <button type="button" @onclick='() => Nav.NavigateTo("/appointments")'
                    class="text-gray-500 hover:text-gray-700 font-medium">
                Cancel and Go Back
            </button>

            <div class="flex flex-col items-end w-full md:w-auto">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm border border-red-200">
                        @_error
                    </div>
                }

                @if (_isSuccess)
                {
                    <div class="mb-4 p-3 bg-green-50 text-green-700 rounded-lg text-sm border border-green-200 flex items-center">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" /></svg>
                        Appointment Confirmed! Redirecting...
                    </div>
                }

                <button type="submit"
                        disabled="@(_isSubmitting || _isSuccess)"
                        class="w-full md:w-auto px-10 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-lg transition duration-200 disabled:opacity-50">
                    @(_isSubmitting ? "Saving..." : "Confirm Appointment")
                </button>
            </div>
        </div>
    </EditForm>
</div>
<UserRegistrationModal Visible="@showRegistrationModal"
                       VisibleChanged="@(EventCallback.Factory.Create<bool>(this, v => showRegistrationModal = v))"
                       IsEditing="false"
                       InitialUserName="@model.CustomerName"
                       InitialEmail="@model.Email"
                       InitialPhoneNumber="@model.PhoneNumber"
                       InitialSSN="@model.SSN"
                       OnSaved="OnUserRegistered" />
@code {


    private string InputClass => "block w-full px-4 py-2 border rounded-lg focus:ring-blue-500 focus:border-blue-500 text-gray-900 " +
                                (IsReadOnly ? "bg-gray-100 cursor-not-allowed" : "bg-white border-gray-300");

    private string GetTimeSlotClass(TimeSpan slot)
    {
        var baseClass = "py-2 px-1 text-sm font-medium rounded-md border transition-all duration-150 ";
        return IsSelected(slot)
            ? baseClass + "bg-blue-600 border-blue-600 text-white shadow-md scale-105"
            : baseClass + "bg-white border-gray-200 text-gray-600 hover:border-blue-400 hover:text-blue-500";
    }
    private List<TimeSpan> TimeSlots = new();

    protected override void OnInitialized()
    {
        Generate15MinuteSlots();
    }

    private void Generate15MinuteSlots()
    {
        var start = new TimeSpan(8, 0, 0); // 8:00 AM
        var end = new TimeSpan(17, 0, 0);  // 5:00 PM
        var interval = TimeSpan.FromMinutes(15);

        var current = start;
        while (current <= end)
        {
            TimeSlots.Add(current);
            current = current.Add(interval);
        }
    }
    private void SelectTime(TimeSpan slot)
    {
        // This combines the existing Date with the new Time selected from the board
        model.Date = model.Date.Date.Add(slot);
    }
    private bool IsSelected(TimeSpan slot)
    {
        return model.Date.TimeOfDay == slot;
    }
}